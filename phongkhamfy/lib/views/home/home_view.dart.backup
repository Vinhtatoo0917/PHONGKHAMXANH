  // ═══════════════════════════════════════════════════════════════
  // HÀM XÂY DỰNG FLOATING ACTION BUTTON (Tối ưu)
  // ═══════════════════════════════════════════════════════════════
  Widget _xayDungFloatingActionButton() {
    return FloatingActionButton(
      onPressed: () {
        _hienThiThongBaoChucNang('Hỗ trợ khẩn cấp');
      },
      backgroundColor: _mauError,
      elevation: 8,
      child: const Icon(
        Icons.emergency_rounded,
        color: Colors.white,
        size: 28,
      ),
    );
  }

  // ═══════════════════════════════════════════════════════════════
  // HÀM XÂY DỰNG BOTTOM NAVIGATION HIỆN ĐẠI
  // ═══════════════════════════════════════════════════════════════
  Widget _xayDungBottomNavigationHienDai() {
    return Container(
      decoration: BoxDecoration(
        color: _mauBeMat,
        boxShadow: [
          BoxShadow(
            color: Colors.black.withValues(alpha: 0.1),
            blurRadius: 20,
            offset: const Offset(0, -5),
          ),
        ],
      ),
      child: ClipRRect(
        borderRadius: const BorderRadius.only(
          topLeft: Radius.circular(24),
          topRight: Radius.circular(24),
        ),
        child: BottomNavigationBar(
          type: BottomNavigationBarType.fixed,
          backgroundColor: _mauBeMat,
          selectedItemColor: _mauChinh,
          unselectedItemColor: _mauChuPhu,
          selectedFontSize: 12,
          unselectedFontSize: 12,
          currentIndex: _selectedBottomIndex,
          onTap: (index) {
            setState(() {
              _selectedBottomIndex = index;
            });
          },
          items: [
            BottomNavigationBarItem(
              icon: Container(
                padding: const EdgeInsets.all(8),
                decoration: BoxDecoration(
                  color: _selectedBottomIndex == 0
                      ? _mauChinh.withValues(alpha: 0.1)
                      : Colors.transparent,
                  borderRadius: BorderRadius.circular(12),
                ),
                child: Icon(
                  _selectedBottomIndex == 0
                      ? Icons.home_rounded
                      : Icons.home_outlined,
                ),
              ),
              label: 'Trang chủ',
            ),
            BottomNavigationBarItem(
              icon: Container(
                padding: const EdgeInsets.all(8),
                decoration: BoxDecoration(
                  color: _selectedBottomIndex == 1
                      ? _mauChinh.withValues(alpha: 0.1)
                      : Colors.transparent,
                  borderRadius: BorderRadius.circular(12),
                ),
                child: Stack(
                  children: [
                    Icon(
                      _selectedBottomIndex == 1
                          ? Icons.notifications_rounded
                          : Icons.notifications_outlined,
                    ),
                    Positioned(
                      top: 0,
                      right: 0,
                      child: Container(
                        width: 8,
                        height: 8,
                        decoration: BoxDecoration(
                          color: _mauError,
                          shape: BoxShape.circle,
                        ),
                      ),
                    ),
                  ],
                ),
              ),
              label: 'Thông báo',
            ),
            BottomNavigationBarItem(
              icon: Container(
                padding: const EdgeInsets.all(8),
                decoration: BoxDecoration(
                  color: _selectedBottomIndex == 2
                      ? _mauChinh.withValues(alpha: 0.1)
                      : Colors.transparent,
                  borderRadius: BorderRadius.circular(12),
                ),
                child: Icon(
                  _selectedBottomIndex == 2
                      ? Icons.calendar_month_rounded
                      : Icons.calendar_month_outlined,
                ),
              ),
              label: 'Lịch hẹn',
            ),
            BottomNavigationBarItem(
              icon: Container(
                padding: const EdgeInsets.all(8),
                decoration: BoxDecoration(
                  color: _selectedBottomIndex == 3
                      ? _mauChinh.withValues(alpha: 0.1)
                      : Colors.transparent,
                  borderRadius: BorderRadius.circular(12),
                ),
                child: Icon(
                  _selectedBottomIndex == 3
                      ? Icons.person_rounded
                      : Icons.person_outline_rounded,
                ),
              ),
              label: 'Cá nhân',
            ),
          ],
        ),
      ),
    );
  }

  // ═══════════════════════════════════════════════════════════════
  // HÀM LẤY TIÊU ĐỀ VÀ MÔ TẢ THEO VAI TRÒ
  // ═══════════════════════════════════════════════════════════════
  String _layTieuDeTheoVaiTro() {
    final vaiTro = widget.vaiTro ?? 'benh_nhan';

    switch (vaiTro) {
      case 'bac_si':
        return 'Công cụ bác sĩ';
      case 'admin':
        return 'Quản trị hệ thống';
      case 'benh_nhan':
      default:
        return 'Dịch vụ y tế';
    }
  }

  /// Lấy mô tả vai trò để hiển thị trong header
  String _layMoTaVaiTro() {
    final vaiTro = widget.vaiTro ?? 'benh_nhan';

    switch (vaiTro) {
      case 'bac_si':
        return 'Bác sĩ';
      case 'admin':
        return 'Quản trị viên';
      case 'benh_nhan':
      default:
        return 'Bệnh nhân';
    }
  }

  // ═══════════════════════════════════════════════════════════════
  // HÀM HIỂN THỊ THÔNG BÁO CHỨC NĂNG THÔNG MINH
  // ═══════════════════════════════════════════════════════════════
  void _hienThiThongBaoChucNang(String tenChucNang) {
    final vaiTro = widget.vaiTro ?? 'benh_nhan';
    String thongBao;
    IconData icon;

    // Tùy chỉnh thông báo theo vai trò
    switch (vaiTro) {
      case 'bac_si':
        thongBao = 'Đang mở công cụ: $tenChucNang';
        icon = Icons.medical_services_rounded;
        break;
      case 'admin':
        thongBao = 'Truy cập quản trị: $tenChucNang';
        icon = Icons.admin_panel_settings_rounded;
        break;
      case 'benh_nhan':
      default:
        thongBao = 'Đang truy cập dịch vụ: $tenChucNang';
        icon = Icons.local_hospital_rounded;
        break;
    }

    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Row(
          children: [
            Container(
              padding: const EdgeInsets.all(8),
              decoration: BoxDecoration(
                color: Colors.white.withValues(alpha: 0.2),
                borderRadius: BorderRadius.circular(8),
              ),
              child: Icon(icon, color: Colors.white, size: 20),
            ),
            const SizedBox(width: 12),
            Expanded(
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                mainAxisSize: MainAxisSize.min,
                children: [
                  Text(
                    thongBao,
                    style: const TextStyle(
                      fontWeight: FontWeight.w600,
                      fontSize: 14,
                    ),
                  ),
                  Text(
                    'Chức năng sẽ được phát triển trong phiên bản tiếp theo',
                    style: TextStyle(
                      fontSize: 12,
                      color: Colors.white.withValues(alpha: 0.8),
                    ),
                  ),
                ],
              ),
            ),
          ],
        ),
        backgroundColor: _mauChinh,
        behavior: SnackBarBehavior.floating,
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(16)),
        margin: const EdgeInsets.all(16),
        duration: const Duration(seconds: 3),
      ),
    );
  }

  // ═══════════════════════════════════════════════════════════════
  // HÀM HIỂN THỊ DIALOG ĐĂNG XUẤT
  // ═══════════════════════════════════════════════════════════════
  void _hienThiDialogDangXuat() {
    DialogDangXuat.hienThi(
      context: context,
      onXacNhan: _dangXuat,
      mauChinh: _mauChinh,
      mauError: _mauError,
      mauBeMat: _mauBeMat,
      mauChuChinh: _mauChuChinh,
      mauChuPhu: _mauChuPhu,
      mauVien: _mauVien,
    );
  }

  // ═══════════════════════════════════════════════════════════════
  // HÀM ĐĂNG XUẤT
  // ═══════════════════════════════════════════════════════════════
  void _dangXuat() {
    // Hiển thị loading
    LoadingDangXuat.hienThi(
      context: context,
      mauChinh: _mauChinh,
      mauBeMat: _mauBeMat,
      mauChuChinh: _mauChuChinh,
      mauChuPhu: _mauChuPhu,
    );

    // Delay để hiển thị loading
    Future.delayed(const Duration(milliseconds: 1500), () {
      if (mounted) {
        Navigator.of(context).pushAndRemoveUntil(
          PageRouteBuilder(
            pageBuilder: (context, animation, secondaryAnimation) =>
                const ManHinhDangNhap(),
            transitionsBuilder:
                (context, animation, secondaryAnimation, child) {
                  const begin = Offset(1.0, 0.0);
                  const end = Offset.zero;
                  const curve = Curves.easeInOutCubic;
                  var tween = Tween(
                    begin: begin,
                    end: end,
                  ).chain(CurveTween(curve: curve));
                  return SlideTransition(
                    position: animation.drive(tween),
                    child: FadeTransition(opacity: animation, child: child),
                  );
                },
            transitionDuration: const Duration(milliseconds: 600),
          ),
          (route) => false,
        );
      }
    });
  }
}
