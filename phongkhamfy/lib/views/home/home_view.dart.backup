  /// Helper function để tạo chức năng một cách nhất quán
  Map<String, dynamic> _taoChucNang(
    String ten,
    IconData icon,
    List<Color> gradient,
    String moTa,
  ) {
    return {
      'ten': ten,
      'icon': icon,
      'mau': gradient.first,
      'gradient': gradient,
      'moTa': moTa,
    };
  }

