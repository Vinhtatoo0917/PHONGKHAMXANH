  @override
  Widget build(BuildContext context) {
    final size = MediaQuery.of(context).size;
    final laDienThoai = size.width < 600;

    return Scaffold(
      backgroundColor: _mauNen,
      body: SafeArea(
        child: CustomScrollView(
          slivers: [
            // ───────────────────────────────────────────────────────
            // SLIVER APP BAR HIỆN ĐẠI
            // ───────────────────────────────────────────────────────
            _xayDungSliverAppBar(laDienThoai),

            // ───────────────────────────────────────────────────────
            // PHẦN THỐNG KÊ NHANH
            // ───────────────────────────────────────────────────────
            SliverToBoxAdapter(child: _xayDungPhanThongKe(laDienThoai)),

            // ───────────────────────────────────────────────────────
            // PHẦN TIN TỨC HIỆN ĐẠI
            // ───────────────────────────────────────────────────────
            SliverToBoxAdapter(child: _xayDungPhanTinTucHienDai(laDienThoai)),

            // ───────────────────────────────────────────────────────
            // PHẦN CHỨC NĂNG HIỆN ĐẠI
            // ───────────────────────────────────────────────────────
            SliverToBoxAdapter(child: _xayDungPhanChucNangHienDai(laDienThoai)),

            // ───────────────────────────────────────────────────────
            // PHẦN DỊCH VỤ NỔI BẬT
            // ───────────────────────────────────────────────────────
            SliverToBoxAdapter(child: _xayDungPhanDichVuNoiBat(laDienThoai)),

            // Khoảng cách cuối
            const SliverToBoxAdapter(child: SizedBox(height: 100)),
          ],
        ),
      ),
      // ─────────────────────────────────────────────────────────────
      // FLOATING ACTION BUTTON
      // ─────────────────────────────────────────────────────────────
      floatingActionButton: _xayDungFloatingActionButton(),

      // ─────────────────────────────────────────────────────────────
      // BOTTOM NAVIGATION BAR HIỆN ĐẠI
      // ─────────────────────────────────────────────────────────────
      bottomNavigationBar: _xayDungBottomNavigationHienDai(),
    );
  }

  // ═══════════════════════════════════════════════════════════════
  // HÀM XÂY DỰNG SLIVER APP BAR (Tối ưu)
  // ═══════════════════════════════════════════════════════════════
  Widget _xayDungSliverAppBar(bool laDienThoai) {
    return SliverAppBar(
      expandedHeight: laDienThoai ? 200 : 250,
      floating: false,
      pinned: true,
      elevation: 0,
      backgroundColor: _mauChinh,
      flexibleSpace: FlexibleSpaceBar(
        background: Container(
          decoration: BoxDecoration(
            gradient: LinearGradient(
              begin: Alignment.topLeft,
              end: Alignment.bottomRight,
              colors: [_mauChinh, _mauChinhDam, _mauAccent],
            ),
          ),
          child: Stack(
            children: [
              // Nội dung chính
              Positioned(
                bottom: laDienThoai ? 20 : 30,
                left: laDienThoai ? 16 : 24,
                right: laDienThoai ? 16 : 24,
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                            Row(
                              children: [
                                Container(
                                  padding: const EdgeInsets.all(12),
                                  decoration: BoxDecoration(
                                    color: Colors.white.withValues(alpha: 0.2),
                                    borderRadius: BorderRadius.circular(16),
                                    border: Border.all(
                                      color: Colors.white.withValues(
                                        alpha: 0.3,
                                      ),
                                      width: 1,
                                    ),
                                  ),
                                  child: Icon(
                                    Icons.local_hospital_rounded,
                                    color: Colors.white,
                                    size: laDienThoai ? 24 : 28,
                                  ),
                                ),
                                const SizedBox(width: 16),
                                Expanded(
                                  child: Column(
                                    crossAxisAlignment:
                                        CrossAxisAlignment.start,
                                    children: [
                                      Text(
                                        'Phòng Khám Xanh',
                                        style: TextStyle(
                                          fontSize: laDienThoai ? 20 : 24,
                                          fontWeight: FontWeight.w800,
                                          color: Colors.white,
                                          letterSpacing: 0.5,
                                        ),
                                      ),
                                      Text(
                                        'Chăm sóc sức khỏe thông minh',
                                        style: TextStyle(
                                          fontSize: laDienThoai ? 13 : 15,
                                          color: Colors.white.withValues(
                                            alpha: 0.9,
                                          ),
                                          fontWeight: FontWeight.w500,
                                        ),
                                      ),
                                    ],
                                  ),
                                ),
                              ],
                            ),

                            const SizedBox(height: 16),

                            Text(
                              'Xin chào, ${widget.tenNguoiDung}! 👋',
                              style: TextStyle(
                                fontSize: laDienThoai ? 18 : 22,
                                fontWeight: FontWeight.w700,
                                color: Colors.white,
                              ),
                            ),
                            const SizedBox(height: 4),
                            Row(
                              children: [
                                Container(
                                  padding: const EdgeInsets.symmetric(
                                    horizontal: 8,
                                    vertical: 4,
                                  ),
                                  decoration: BoxDecoration(
                                    color: Colors.white.withValues(alpha: 0.2),
                                    borderRadius: BorderRadius.circular(12),
                                    border: Border.all(
                                      color: Colors.white.withValues(
                                        alpha: 0.3,
                                      ),
                                      width: 1,
                                    ),
                                  ),
                                  child: Text(
                                    _layMoTaVaiTro(),
                                    style: TextStyle(
                                      fontSize: laDienThoai ? 11 : 13,
                                      color: Colors.white,
                                      fontWeight: FontWeight.w600,
                                    ),
                                  ),
                                ),
                                const SizedBox(width: 8),
                                Expanded(
                                  child: Text(
                                    'Hôm nay bạn cảm thấy thế nào?',
                                    style: TextStyle(
                                      fontSize: laDienThoai ? 14 : 16,
                                      color: Colors.white.withValues(
                                        alpha: 0.9,
                                      ),
                                      fontWeight: FontWeight.w500,
                                    ),
                                  ),
                                ),
                              ],
                            ),
                          ],
                        ),
                      ),
                    ],
                  ),
                ),
              ),
            );
          },
        ),
      ),
      actions: [
        IconButton(
          onPressed: () {},
          icon: Container(
            padding: const EdgeInsets.all(8),
            decoration: BoxDecoration(
              color: Colors.white.withValues(alpha: 0.2),
              borderRadius: BorderRadius.circular(12),
            ),
            child: const Icon(
              Icons.notifications_rounded,
              color: Colors.white,
              size: 20,
            ),
          ),
        ),
        IconButton(
          onPressed: _hienThiDialogDangXuat,
          icon: Container(
            padding: const EdgeInsets.all(8),
            decoration: BoxDecoration(
              color: Colors.white.withValues(alpha: 0.2),
              borderRadius: BorderRadius.circular(12),
            ),
            child: const Icon(
              Icons.logout_rounded,
              color: Colors.white,
              size: 20,
            ),
          ),
        ),
        const SizedBox(width: 8),
      ],
    );
  }

  // ═══════════════════════════════════════════════════════════════
  // HÀM XÂY DỰNG PHẦN THỐNG KÊ (Tối ưu)
  // ═══════════════════════════════════════════════════════════════
  Widget _xayDungPhanThongKe(bool laDienThoai) {
    return Container(
      margin: EdgeInsets.all(laDienThoai ? 16 : 24),
      child: Row(
        children: _thongKe.asMap().entries.map((entry) {
          final index = entry.key;
          final item = entry.value;

          return Expanded(
            child: Container(
              margin: EdgeInsets.only(
                right: index < _thongKe.length - 1
                    ? (laDienThoai ? 8 : 12)
                    : 0,
              ),
              padding: EdgeInsets.all(laDienThoai ? 16 : 20),
              decoration: BoxDecoration(
                color: _mauBeMat,
                borderRadius: BorderRadius.circular(
                  laDienThoai ? 16 : 20,
                ),
                boxShadow: [
                  BoxShadow(
                    color: item['mau'].withValues(alpha: 0.1),
                    blurRadius: 20,
                    offset: const Offset(0, 8),
                  ),
                ],
                border: Border.all(
                  color: item['mau'].withValues(alpha: 0.1),
                  width: 1,
                ),
              ),
              child: Column(
                children: [
                  Container(
                    padding: const EdgeInsets.all(12),
                    decoration: BoxDecoration(
                              color: item['mau'].withValues(alpha: 0.1),
                              borderRadius: BorderRadius.circular(12),
                            ),
                            child: Icon(
                              item['icon'],
                              color: item['mau'],
                              size: laDienThoai ? 20 : 24,
                            ),
                          ),
                          const SizedBox(height: 12),
                          Text(
                            item['giaTri'],
                            style: TextStyle(
                              fontSize: laDienThoai ? 20 : 24,
                              fontWeight: FontWeight.w800,
                              color: _mauChuChinh,
                            ),
                          ),
                          const SizedBox(height: 4),
                          Text(
                            item['donVi'],
                            style: TextStyle(
                              fontSize: laDienThoai ? 10 : 12,
                              color: _mauChuPhu,
                              fontWeight: FontWeight.w500,
                            ),
                            textAlign: TextAlign.center,
                          ),
                        ],
                      ),
                    ),
                  );
                }).toList(),
              ),
            ),
          ),
        );
      },
    );
  }

  // ═══════════════════════════════════════════════════════════════
  // HÀM XÂY DỰNG PHẦN TIN TỨC (Tối ưu)
  // ═══════════════════════════════════════════════════════════════
  Widget _xayDungPhanTinTucHienDai(bool laDienThoai) {
    return Container(
      margin: EdgeInsets.symmetric(horizontal: laDienThoai ? 16 : 24),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          // Tiêu đề phần
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
              Text(
                'Tin tức y tế',
                style: TextStyle(
                  fontSize: laDienThoai ? 20 : 24,
                  fontWeight: FontWeight.w800,
                  color: _mauChuChinh,
                ),
              ),
              Container(
                padding: const EdgeInsets.symmetric(
                  horizontal: 12,
                  vertical: 6,
                ),
                decoration: BoxDecoration(
                  color: _mauChinh.withValues(alpha: 0.1),
                  borderRadius: BorderRadius.circular(20),
                ),
                child: Text(
                  'Xem tất cả',
                  style: TextStyle(
                    fontSize: laDienThoai ? 12 : 14,
                    color: _mauChinh,
                    fontWeight: FontWeight.w600,
                  ),
                ),
              ),
            ],
          ),

          const SizedBox(height: 16),

          // Danh sách tin tức với PageView
          SizedBox(
            height: laDienThoai ? 180 : 220,
            child: PageView.builder(
              controller: _newsPageController,
              onPageChanged: (index) {
                setState(() {
                  _currentNewsIndex = index;
                });
              },
              itemCount: _danhSachTinTuc.length,
              itemBuilder: (context, index) {
                final tinTuc = _danhSachTinTuc[index];
                return Container(
                  margin: const EdgeInsets.only(right: 16),
                  decoration: BoxDecoration(
                    borderRadius: BorderRadius.circular(
                      laDienThoai ? 20 : 24,
                    ),
                    gradient: LinearGradient(
                      begin: Alignment.topLeft,
                      end: Alignment.bottomRight,
                      colors: [
                        tinTuc['mauNen'],
                        tinTuc['mauNen'].withValues(alpha: 0.8),
                      ],
                    ),
                    boxShadow: [
                      BoxShadow(
                        color: tinTuc['mauNen'].withValues(alpha: 0.3),
                        blurRadius: 20,
                        offset: const Offset(0, 10),
                      ),
                    ],
                  ),
                  child: Stack(
                    children: [
                      // Nội dung
                      Padding(
                        padding: EdgeInsets.all(laDienThoai ? 20 : 24),
                        child: Column(
                                  crossAxisAlignment: CrossAxisAlignment.start,
                                  children: [
                                    // Icon và thời gian
                                    Row(
                                      mainAxisAlignment:
                                          MainAxisAlignment.spaceBetween,
                                      children: [
                                        Container(
                                          padding: const EdgeInsets.all(12),
                                          decoration: BoxDecoration(
                                            color: Colors.white.withValues(
                                              alpha: 0.2,
                                            ),
                                            borderRadius: BorderRadius.circular(
                                              16,
                                            ),
                                          ),
                                          child: Text(
                                            tinTuc['hinhAnh'],
                                            style: TextStyle(
                                              fontSize: laDienThoai ? 24 : 28,
                                            ),
                                          ),
                                        ),
                                        Container(
                                          padding: const EdgeInsets.symmetric(
                                            horizontal: 8,
                                            vertical: 4,
                                          ),
                                          decoration: BoxDecoration(
                                            color: Colors.white.withValues(
                                              alpha: 0.2,
                                            ),
                                            borderRadius: BorderRadius.circular(
                                              12,
                                            ),
                                          ),
                                          child: Text(
                                            tinTuc['thoiGian'],
                                            style: TextStyle(
                                              fontSize: laDienThoai ? 10 : 12,
                                              color: Colors.white,
                                              fontWeight: FontWeight.w500,
                                            ),
                                          ),
                                        ),
                                      ],
                                    ),

                                    const Spacer(),

                                    // Tiêu đề
                                    Text(
                                      tinTuc['tieuDe'],
                                      style: TextStyle(
                                        fontSize: laDienThoai ? 16 : 18,
                                        fontWeight: FontWeight.w700,
                                        color: Colors.white,
                                        height: 1.3,
                                      ),
                                      maxLines: 2,
                                      overflow: TextOverflow.ellipsis,
                                    ),

                                    const SizedBox(height: 8),

                                    // Mô tả
                                    Text(
                                      tinTuc['moTa'],
                                      style: TextStyle(
                                        fontSize: laDienThoai ? 13 : 15,
                                        color: Colors.white.withValues(
                                          alpha: 0.9,
                                        ),
                                        height: 1.4,
                                      ),
                                      maxLines: 2,
                                      overflow: TextOverflow.ellipsis,
                                    ),

                                    const SizedBox(height: 12),

                                    // Lượt xem
                                    Row(
                                      children: [
                                        Icon(
                                          Icons.visibility_rounded,
                                          size: laDienThoai ? 14 : 16,
                                          color: Colors.white.withValues(
                                            alpha: 0.8,
                                          ),
                                        ),
                                        const SizedBox(width: 4),
                                        Text(
                                          '${tinTuc['luotXem']} lượt xem',
                                          style: TextStyle(
                                            fontSize: laDienThoai ? 11 : 13,
                                            color: Colors.white.withValues(
                                              alpha: 0.8,
                                            ),
                                            fontWeight: FontWeight.w500,
                                          ),
                                        ),
                                      ],
                                    ),
                                  ],
                                ),
                              ),
                            ],
                          ),
                        );
                      },
                    ),
                  ),

                  // Indicator dots hiện đại
                  const SizedBox(height: 16),
                  Row(
                    mainAxisAlignment: MainAxisAlignment.center,
                    children: List.generate(
                      _danhSachTinTuc.length,
                      (index) => AnimatedContainer(
                        duration: const Duration(milliseconds: 300),
                        width: index == _currentNewsIndex ? 24 : 8,
                        height: 8,
                        margin: const EdgeInsets.symmetric(horizontal: 4),
                        decoration: BoxDecoration(
                          color: index == _currentNewsIndex
                              ? _mauChinh
                              : _mauChinh.withValues(alpha: 0.3),
                          borderRadius: BorderRadius.circular(4),
                        ),
                      ),
                    ),
                  ),
                ],
              ),
            ),
          ),
        );
      },
    );
  }

  // ═══════════════════════════════════════════════════════════════
  // HÀM XÂY DỰNG PHẦN CHỨC NĂNG (Tối ưu)
  // ═══════════════════════════════════════════════════════════════
  Widget _xayDungPhanChucNangHienDai(bool laDienThoai) {
    return Container(
      margin: EdgeInsets.all(laDienThoai ? 16 : 24),
      padding: EdgeInsets.all(laDienThoai ? 20 : 28),
      decoration: BoxDecoration(
        color: _mauBeMat,
        borderRadius: BorderRadius.circular(laDienThoai ? 24 : 28),
        boxShadow: [
          BoxShadow(
            color: _mauChinh.withValues(alpha: 0.08),
            blurRadius: 30,
            offset: const Offset(0, 15),
          ),
          BoxShadow(
            color: Colors.black.withValues(alpha: 0.04),
            blurRadius: 10,
            offset: const Offset(0, 5),
          ),
        ],
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
                  // Tiêu đề với icon
                  Row(
                    children: [
                      Container(
                        padding: const EdgeInsets.all(8),
                        decoration: BoxDecoration(
                          color: _mauChinh.withValues(alpha: 0.1),
                          borderRadius: BorderRadius.circular(12),
                        ),
                        child: Icon(
                          Icons.apps_rounded,
                          color: _mauChinh,
                          size: laDienThoai ? 20 : 24,
                        ),
                      ),
                      const SizedBox(width: 12),
                      Text(
                        _layTieuDeTheoVaiTro(),
                        style: TextStyle(
                          fontSize: laDienThoai ? 20 : 24,
                          fontWeight: FontWeight.w800,
                          color: _mauChuChinh,
                        ),
                      ),
                      const Spacer(),
                      // Search và filter icons như trong UMC Care
                      Container(
                        padding: const EdgeInsets.all(8),
                        decoration: BoxDecoration(
                          color: _mauNen,
                          borderRadius: BorderRadius.circular(8),
                          border: Border.all(color: _mauVien),
                        ),
                        child: Icon(
                          Icons.tune_rounded,
                          color: _mauChuPhu,
                          size: laDienThoai ? 16 : 18,
                        ),
                      ),
                      const SizedBox(width: 8),
                      Container(
                        padding: const EdgeInsets.all(8),
                        decoration: BoxDecoration(
                          color: _mauNen,
                          borderRadius: BorderRadius.circular(8),
                          border: Border.all(color: _mauVien),
                        ),
                        child: Icon(
                          Icons.search_rounded,
                          color: _mauChuPhu,
                          size: laDienThoai ? 16 : 18,
                        ),
                      ),
                    ],
                  ),

                  const SizedBox(height: 20),

                  // Grid chức năng với animation (4 cột như UMC Care)
                  GridView.builder(
                    shrinkWrap: true,
                    physics: const NeverScrollableScrollPhysics(),
                    gridDelegate: SliverGridDelegateWithFixedCrossAxisCount(
                      crossAxisCount: 4, // 4 cột như trong ảnh UMC Care
                      childAspectRatio: laDienThoai ? 0.85 : 1.0,
                      crossAxisSpacing: laDienThoai ? 8 : 12,
                      mainAxisSpacing: laDienThoai ? 16 : 20,
                    ),
                    itemCount: _danhSachChucNang.length,
                    itemBuilder: (context, index) {
                      final chucNang = _danhSachChucNang[index];
                      return TweenAnimationBuilder<double>(
                        duration: Duration(milliseconds: 600 + (index * 100)),
                        tween: Tween(begin: 0.0, end: 1.0),
                        builder: (context, value, child) {
                          return Transform.scale(
                            scale: value,
                            child: GestureDetector(
                              onTap: () {
                                // Hiệu ứng nhấn
                                _hienThiThongBaoChucNang(chucNang['ten']);
                              },
                              child: Container(
                                padding: EdgeInsets.all(laDienThoai ? 8 : 12),
                                decoration: BoxDecoration(
                                  color: _mauBeMat,
                                  borderRadius: BorderRadius.circular(
                                    laDienThoai ? 12 : 16,
                                  ),
                                  boxShadow: [
                                    BoxShadow(
                                      color: chucNang['mau'].withValues(
                                        alpha: 0.1,
                                      ),
                                      blurRadius: 8,
                                      offset: const Offset(0, 2),
                                    ),
                                  ],
                                  border: Border.all(
                                    color: chucNang['mau'].withValues(
                                      alpha: 0.1,
                                    ),
                                    width: 1,
                                  ),
                                ),
                                child: Column(
                                  mainAxisAlignment: MainAxisAlignment.center,
                                  children: [
                                    // Icon với background gradient tròn
                                    Container(
                                      padding: EdgeInsets.all(
                                        laDienThoai ? 10 : 14,
                                      ),
                                      decoration: BoxDecoration(
                                        gradient: LinearGradient(
                                          begin: Alignment.topLeft,
                                          end: Alignment.bottomRight,
                                          colors: chucNang['gradient'],
                                        ),
                                        borderRadius: BorderRadius.circular(
                                          laDienThoai ? 10 : 14,
                                        ),
                                        boxShadow: [
                                          BoxShadow(
                                            color: chucNang['mau'].withValues(
                                              alpha: 0.3,
                                            ),
                                            blurRadius: 6,
                                            offset: const Offset(0, 2),
                                          ),
                                        ],
                                      ),
                                      child: Icon(
                                        chucNang['icon'],
                                        color: Colors.white,
                                        size: laDienThoai ? 18 : 22,
                                      ),
                                    ),

                                    SizedBox(height: laDienThoai ? 6 : 8),

                                    // Tên chức năng
                                    Padding(
                                      padding: const EdgeInsets.symmetric(
                                        horizontal: 2,
                                      ),
                                      child: Text(
                                        chucNang['ten'],
                                        style: TextStyle(
                                          fontSize: laDienThoai ? 10 : 12,
                                          fontWeight: FontWeight.w600,
                                          color: _mauChuChinh,
                                          height: 1.2,
                                        ),
                                        textAlign: TextAlign.center,
                                        maxLines: 2,
                                        overflow: TextOverflow.ellipsis,
                                      ),
                                    ),
                                  ],
                                ),
                              ),
                            ),
                          );
                        },
                      );
                    },
                  ),
                ],
              ),
            ),
          ),
        );
      },
    );
  }

  // ═══════════════════════════════════════════════════════════════
  // HÀM XÂY DỰNG PHẦN DỊCH VỤ NỔI BẬT
  // ═══════════════════════════════════════════════════════════════
  Widget _xayDungPhanDichVuNoiBat(bool laDienThoai) {
