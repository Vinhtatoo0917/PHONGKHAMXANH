  // ─────────────────────────────────────────────────────────────
  // MÀU SẮC HIỆN ĐẠI
  // ─────────────────────────────────────────────────────────────
  static const Color _mauChinh = Color(0xFF00C896);
  static const Color _mauChinhDam = Color(0xFF00A67E);
  static const Color _mauNen = Color(0xFFF8FFFE);
  static const Color _mauBeMat = Colors.white;
  static const Color _mauChuChinh = Color(0xFF1A2B3D);
  static const Color _mauChuPhu = Color(0xFF6B7C8A);
  static const Color _mauVien = Color(0xFFE8F4F1);
  static const Color _mauAccent = Color(0xFF4ECDC4);
  static const Color _mauError = Color(0xFFFF7043);

  @override
  void initState() {
    super.initState();
    _khoiTaoAnimations();
    _batDauAnimations();
  }

  @override
  void dispose() {
    _fadeAnimationController.dispose();
    _newsPageController.dispose();
    super.dispose();
  }

  // ═══════════════════════════════════════════════════════════════
  // HÀM KHỞI TẠO ANIMATIONS (Tối ưu)
  // ═══════════════════════════════════════════════════════════════
  void _khoiTaoAnimations() {
    // Chỉ dùng 1 animation đơn giản
    _fadeAnimationController = AnimationController(
      duration: const Duration(milliseconds: 600),
      vsync: this,
    );
    _fadeAnimation = CurvedAnimation(
      parent: _fadeAnimationController,
      curve: Curves.easeOut,
    );
  }

  // ═══════════════════════════════════════════════════════════════
  // HÀM BẮT ĐẦU ANIMATIONS (Tối ưu)
  // ═══════════════════════════════════════════════════════════════
  void _batDauAnimations() {
    _fadeAnimationController.forward();
  }

