  /// Lấy danh sách chức năng dựa trên vai trò người dùng
  /// Cách tiếp cận mới: tập trung vào trải nghiệm người dùng
  List<Map<String, dynamic>> get _danhSachChucNang {
    final vaiTro = widget.vaiTro ?? 'benh_nhan';

    switch (vaiTro) {
      case 'bac_si':
        return _layChucNangBacSi();
      case 'admin':
        return _layChucNangAdmin();
      case 'benh_nhan':
      default:
        return _layChucNangBenhNhan();
    }
  }

