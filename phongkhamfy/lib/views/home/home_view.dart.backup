// ═══════════════════════════════════════════════════════════════
// CLASS: ManHinhTrangChu
// MÔ TẢ: Màn hình trang chủ với thiết kế hiện đại và nhiều tính năng
// LOẠI: StatefulWidget (có thể thay đổi trạng thái)
// ═══════════════════════════════════════════════════════════════
class ManHinhTrangChu extends StatefulWidget {
  final String tenNguoiDung;
  final String email;
  final String? vaiTro; // Thêm vai trò để phân biệt chức năng

  const ManHinhTrangChu({
    super.key,
    required this.tenNguoiDung,
    required this.email,
    this.vaiTro,
  });

  @override
  State<ManHinhTrangChu> createState() => _TrangThaiManHinhTrangChu();
}

// ═══════════════════════════════════════════════════════════════
