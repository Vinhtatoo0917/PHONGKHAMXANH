  late Animation<double> _fadeAnimation;

  // ─────────────────────────────────────────────────────────────
  // TRẠNG THÁI
  // ─────────────────────────────────────────────────────────────
  int _currentNewsIndex = 0;
  int _selectedBottomIndex = 0;
